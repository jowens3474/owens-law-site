# Postgres connection string. For local dev with pgvector:
#   docker run -d --name civic-pg -p 5432:5432 -e POSTGRES_PASSWORD=postgres pgvector/pgvector:pg16
DATABASE_URL=postgres://postgres:postgres@localhost:5432/civic_docs

# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Voyage AI key for embeddings — https://voyageai.com/
# (Anthropic-recommended embedding provider)
VOYAGE_API_KEY=

# The single entity this instance serves (MVP: one entity at a time)
ENTITY_NAME="City of Example"
ENTITY_DESCRIPTION="A mid-sized US municipality."
